# ─── LinkedIn ────────────────────────────────────────────────────────────────
# Get CLIENT_ID and CLIENT_SECRET from your LinkedIn app's Auth tab:
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# These are filled in AFTER running linkedin_token_collection.py:
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_ORG_ID_KAVI_GLOBAL=
LINKEDIN_ORG_ID_KAVI_PHILIPPINES=

# ─── Azure SQL ────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=mcckavi.database.windows.net
AZURE_SQL_DB=mcc
AZURE_SQL_USER=mccuser
AZURE_SQL_PWD=
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# ─── YouTube ─────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── Facebook ────────────────────────────────────────────────────────────────
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_TOKEN_KAVI_PHILIPPINES=
FB_PAGE_TOKEN_KAVI_GLOBAL=

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
GA4_PROPERTY_ID=

# ─── Mailchimp ────────────────────────────────────────────────────────────────
# For local dev OAuth flow:
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=
MAILCHIMP_REDIRECT_URI=http://127.0.0.1:8000/callback
FLASK_SECRET_KEY=

# For CI (set these after completing the one-time OAuth flow locally):
MAILCHIMP_ACCESS_TOKEN=
MAILCHIMP_API_ROOT=          # e.g. https://us1.api.mailchimp.com/3.0

# Optional overrides:
# MAILCHIMP_EXPORT_DIR=export_mailchimp
# MAILCHIMP_SINCE_SEND_TIME=2018-01-01T00:00:00Z
# MAILCHIMP_AUDIENCE_HISTORY_START_DATE=2018-01-01

# ─── Dripify (Google Sheets) ──────────────────────────────────────────────────
# Option A (easiest): base64-encode your existing dripify/token.pickle and store it.
#   Generate with:  base64 -i dripify/token.pickle | tr -d '\n'
GOOGLE_TOKEN_PICKLE_B64=

# Option B: Google Service Account JSON (more robust, requires GCP setup).
#   The service account must have Viewer access to the Dripify Google Sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=
